# 이 파일을 복사해 `.env` 로 저장한 뒤 실제 값을 채우세요.
# cp .env.example .env

# Anthropic Claude API (에이전트 분석)
ANTHROPIC_API_KEY=

# 금융감독원 전자공시 DART API (재무·공시)
DART_API_KEY=

# 한국은행 ECOS Open API (금리·환율·물가 등 거시지표)
ECOS_API_KEY=

# 백그라운드 데이터 갱신 (Phase 4)
# true / 1 / yes / on 이면 앱 기동 시 주기 작업 루프 실행
SCHEDULER_ENABLED=false
# 갱신 주기(초). 최소 60, 최대 86400
SCHEDULER_INTERVAL_SECONDS=3600
