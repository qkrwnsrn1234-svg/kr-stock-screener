# 이 파일을 복사해 `.env` 로 저장한 뒤 실제 값을 채우세요.
# cp .env.example .env

# Anthropic Claude API (에이전트 분석)
ANTHROPIC_API_KEY=
# CEO 종합 요약에 사용할 모델 및 호출 여부
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_CEO_SUMMARY_ENABLED=true

# 금융감독원 전자공시 DART API (재무·공시)
DART_API_KEY=

# 한국은행 ECOS Open API (금리·환율·물가 등 거시지표)
ECOS_API_KEY=

# 저장소 설정 (기본값: SQLite)
# DATABASE_URL이 postgresql:// 로 시작하면 PostgreSQL을 사용합니다.
# 예 (호스트 로컬): postgresql://krstock:krstock@localhost:5432/krstock
# 예 (compose 네트워크 안 api 컨테이너): postgresql://krstock:krstock@db:5432/krstock
DATABASE_URL=
# SQLite 사용 시 파일 경로를 직접 지정하고 싶을 때만 설정하세요.
ANALYSIS_DB_PATH=
WATCHLIST_DB_PATH=
# compose.yml 의 db(profile postgres). 기본값과 맞추면 됩니다.
POSTGRES_USER=krstock
POSTGRES_PASSWORD=krstock
POSTGRES_DB=krstock
POSTGRES_PORT=5432
# HTTP 서버 (Phase 5). 미설정 시 기본 리슨 포트는 18000.
# 플라이 등 호스팅은 PORT를 자동 주입함 — 그때 바인드는 이미지의 BIND_HOST 기준과 맞춤.
PORT=18000
# BIND_HOST: 로컬 기본은 127.0.0.1, Dockerfile 은 0.0.0.0 이라 외부에서 접속 가능
# BIND_HOST=127.0.0.1
# 선호 PORT가 다른 프로세스에 점유되면 같은 호스트상 다음 빈 포트 탐색(로컬 기본 true).
# Docker/docker compose 이미지는 SERVER_PORT_AUTOSCAN=false 로 고정 매핑 권장.
SERVER_PORT_AUTOSCAN=true
# python -m backend.run_uvicorn 사용 시 코드 변경 자동 재시작(uvicorn reload)
SERVER_DEV_RELOAD=false

# 단일 서버(Phase 5): React dist 경로·정적 서빙
FRONTEND_DIST_DIR=
# true(기본): dist 있으면 / 에 SPA 제공. false 면 API만
SERVE_SPA=true

# 백그라운드 데이터 갱신 (Phase 4)
# true / 1 / yes / on 이면 앱 기동 시 주기 작업 루프 실행
SCHEDULER_ENABLED=false
# 갱신 주기(초). 최소 60, 최대 86400
SCHEDULER_INTERVAL_SECONDS=3600

# 과열·저평가 알림 (Phase 4) — Slack Incoming Webhook URL 또는 SMTP(택1 또는 병행)
# 예: https://hooks.slack.com/services/...
ALERT_WEBHOOK_URL=
# 알림 on/off (기본 true)
ALERT_ON_OVERHEAT=true
ALERT_ON_UNDERVALUE=true
# undervalue_score(0~100)가 이 값 이상이면 저평가 후보 알림
ALERT_UNDERVALUE_MIN_SCORE=72
# 동일 종목·유형 재알림 최소 간격(초)
ALERT_COOLDOWN_SECONDS=3600

# 메일 (SMTP). 호스트·수신·발신이 모두 있어야 전송 시도
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USE_TLS=true
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
